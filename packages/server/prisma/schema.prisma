datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                     String                  @id @default(uuid())
  email                  String                  @unique
  passwordHash           String
  name                   String
  status                 UserStatus              @default(ACTIVE)
  globalRole             GlobalRole              @default(MEMBER)
  memberships            TeamMembership[]
  auditLogs              AuditLog[]              @relation("AuditActor")
  targetAuditLogs        AuditLog[]              @relation("AuditTargetUser")
  networkApplyOperations NetworkApplyOperation[]
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
}

model Team {
  id          String           @id @default(uuid())
  name        String           @unique
  status      TeamStatus       @default(ACTIVE)
  memberships TeamMembership[]
  endpoints   AgentEndpoint[]
  auditLogs   AuditLog[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model TeamMembership {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  teamId    String
  team      Team             @relation(fields: [teamId], references: [id])
  role      TeamRole
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([userId, teamId])
  @@index([teamId])
}

model AgentEndpoint {
  id                    String                   @id @default(uuid())
  name                  String
  url                   String
  tokenCiphertext       String?
  status                EndpointStatus           @default(ACTIVE)
  teamId                String
  team                  Team                     @relation(fields: [teamId], references: [id])
  hostState             HostState?
  projectBindings       EndpointProjectBinding[]
  resourceOwnerships    ResourceOwnership[]
  hostNetworkPeers      HostNetworkPeer[]
  networkStateSnapshots NetworkStateSnapshot[]
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@unique([teamId, name])
}

model AuditLog {
  id           String   @id @default(uuid())
  actorId      String
  actor        User     @relation("AuditActor", fields: [actorId], references: [id])
  targetType   String
  targetId     String
  targetUserId String?
  targetUser   User?    @relation("AuditTargetUser", fields: [targetUserId], references: [id])
  teamId       String?
  team         Team?    @relation(fields: [teamId], references: [id])
  action       String
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([teamId])
}

model Tenant {
  id                 String               @id @default(uuid())
  name               String
  slug               String               @unique
  status             TenantStatus         @default(ACTIVE)
  defaultProjectId   String?              @unique
  defaultProject     Project?             @relation("TenantDefaultProject", fields: [defaultProjectId, id], references: [id, ownerTenantId], onDelete: Restrict)
  ownedProjects      Project[]            @relation("ProjectOwnerTenant")
  projectMemberships ProjectTenant[]
  quotaAllocations   ProjectTenantQuota[]
  resourceOwnerships ResourceOwnership[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@unique([defaultProjectId, id])
}

model Project {
  id                 String                   @id @default(uuid())
  name               String
  slug               String
  status             ProjectStatus            @default(ACTIVE)
  ownerTenantId      String
  ownerTenant        Tenant                   @relation("ProjectOwnerTenant", fields: [ownerTenantId], references: [id])
  defaultForTenant   Tenant?                  @relation("TenantDefaultProject")
  tenantMemberships  ProjectTenant[]
  quota              ProjectQuota?
  tenantQuotas       ProjectTenantQuota[]
  endpointBindings   EndpointProjectBinding[]
  resourceOwnerships ResourceOwnership[]
  networkPools       ProjectNetworkPool[]
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@unique([ownerTenantId, slug])
  @@unique([id, ownerTenantId])
  @@index([ownerTenantId])
}

model ProjectTenant {
  id                 String              @id @default(uuid())
  projectId          String
  project            Project             @relation(fields: [projectId], references: [id])
  tenantId           String
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  role               ProjectTenantRole
  status             ProjectTenantStatus @default(ACTIVE)
  quotaAllocation    ProjectTenantQuota?
  resourceOwnerships ResourceOwnership[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([projectId, tenantId])
  @@index([tenantId])
}

model ProjectQuota {
  projectId        String   @id
  project          Project  @relation(fields: [projectId], references: [id])
  maxVcpu          Int?
  maxMemoryBytes   BigInt?
  maxDiskBytes     BigInt?
  maxInstances     Int?
  maxIpv6Addresses Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ProjectTenantQuota {
  projectId        String
  projectTenant    ProjectTenant @relation(fields: [projectId, tenantId], references: [projectId, tenantId])
  project          Project       @relation(fields: [projectId], references: [id])
  tenantId         String
  tenant           Tenant        @relation(fields: [tenantId], references: [id])
  maxVcpu          Int?
  maxMemoryBytes   BigInt?
  maxDiskBytes     BigInt?
  maxInstances     Int?
  maxIpv6Addresses Int?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@id([projectId, tenantId])
  @@index([tenantId])
}

model EndpointProjectBinding {
  id                 String                       @id @default(uuid())
  endpointId         String
  endpoint           AgentEndpoint                @relation(fields: [endpointId], references: [id])
  projectId          String
  project            Project                      @relation(fields: [projectId], references: [id])
  status             EndpointProjectBindingStatus @default(ACTIVE)
  resourceOwnerships ResourceOwnership[]
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  @@unique([endpointId, projectId])
  @@index([projectId])
}

model ResourceOwnership {
  id                     String                 @id @default(uuid())
  resourceType           ResourceType
  resourceId             String
  endpointId             String
  endpointProjectBinding EndpointProjectBinding @relation(fields: [endpointId, projectId], references: [endpointId, projectId])
  projectTenant          ProjectTenant          @relation(fields: [projectId, tenantId], references: [projectId, tenantId])
  endpoint               AgentEndpoint          @relation(fields: [endpointId], references: [id])
  projectId              String
  project                Project                @relation(fields: [projectId], references: [id])
  tenantId               String
  tenant                 Tenant                 @relation(fields: [tenantId], references: [id])
  discoveredName         String?
  externalFingerprint    String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  @@unique([resourceType, endpointId, resourceId])
  @@index([projectId])
  @@index([tenantId])
}

model HostState {
  id                      String          @id @default(uuid())
  endpointId              String          @unique
  endpoint                AgentEndpoint   @relation(fields: [endpointId], references: [id])
  agentId                 String
  agentVersion            String
  agentStateSchemaVersion Int
  agentStartedAt          DateTime
  agentReportedAt         DateTime
  hostHostname            String
  hostOs                  String
  hostArch                String
  incusAvailable          Boolean
  incusStatusCode         Int
  incusServerVersion      String?
  incusApiVersion         String?
  capabilityIncusProxy    Boolean
  capabilityEvents        Boolean
  capabilityStateReport   Boolean
  capabilityWireGuard     Boolean
  capabilityVmLifecycle   Boolean
  snapshotInstancesTotal  Int
  snapshotImagesTotal     Int
  snapshotOperationsTotal Int
  status                  HostStateStatus @default(ONLINE)
  firstSeenAt             DateTime        @default(now())
  lastSeenAt              DateTime
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  @@index([agentId])
  @@index([lastSeenAt])
}

enum GlobalRole {
  ADMIN
  MEMBER
}

enum TeamRole {
  OWNER
  MAINTAINER
  VIEWER
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum TeamStatus {
  ACTIVE
  ARCHIVED
}

enum MembershipStatus {
  ACTIVE
  REMOVED
}

enum EndpointStatus {
  ACTIVE
  ARCHIVED
}

enum TenantStatus {
  ACTIVE
  ARCHIVED
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum ProjectTenantRole {
  OWNER
  PARTICIPANT
}

enum ProjectTenantStatus {
  ACTIVE
  REMOVED
}

enum EndpointProjectBindingStatus {
  ACTIVE
  REMOVED
}

enum ResourceType {
  INSTANCE
  IMAGE
  OPERATION
}

enum HostStateStatus {
  ONLINE
}

// M12 Phase 2: Anvil-managed WireGuard/VPC network foundation.
// Fabrics, hubs, host peers, prefixes, project pools, and apply operations.
// WireGuard private keys and preshared keys are stored only as ciphertext.
// Browser-safe serialization never exposes private keys or preshared keys.

model NetworkFabric {
  id                    String                 @id @default(uuid())
  name                  String
  slug                  String                 @unique
  status                NetworkFabricStatus    @default(PLANNED)
  mode                  NetworkFabricMode      @default(HUB_SPOKE)
  overlayIpv4Cidr       String
  overlayIpv6Cidr       String
  hubs                  WireGuardHub[]
  peers                 HostNetworkPeer[]
  prefixes              FabricPrefix[]
  pools                 ProjectNetworkPool[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  networkStateSnapshots NetworkStateSnapshot[]

  @@index([status])
}

model WireGuardHub {
  id                   String                  @id @default(uuid())
  fabricId             String
  fabric               NetworkFabric           @relation(fields: [fabricId], references: [id])
  name                 String
  status               WireGuardHubStatus      @default(PLANNED)
  listenPort           Int
  endpointHost         String
  publicKey            String                  @unique
  privateKeyCiphertext String
  presharedKeyMode     NetworkPresharedKeyMode @default(DISABLED)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  @@unique([fabricId, name])
  @@index([fabricId])
  @@index([status])
}

model HostNetworkPeer {
  id                     String                @id @default(uuid())
  fabricId               String
  fabric                 NetworkFabric         @relation(fields: [fabricId], references: [id])
  endpointId             String?
  endpoint               AgentEndpoint?        @relation(fields: [endpointId], references: [id], onDelete: SetNull)
  name                   String
  status                 HostNetworkPeerStatus @default(PLANNED)
  role                   HostNetworkPeerRole   @default(MEMBER)
  publicKey              String                @unique
  privateKeyCiphertext   String
  presharedKeyCiphertext String?
  overlayIpv4Address     String?
  overlayIpv6Address     String?
  ownedPrefixes          FabricPrefix[]
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  @@unique([fabricId, name])
  @@index([fabricId])
  @@index([endpointId])
  @@index([status])
}

model FabricPrefix {
  id          String             @id @default(uuid())
  fabricId    String
  fabric      NetworkFabric      @relation(fields: [fabricId], references: [id])
  kind        FabricPrefixKind
  cidr        String
  family      Int
  status      FabricPrefixStatus @default(ACTIVE)
  ownerPeerId String?
  ownerPeer   HostNetworkPeer?   @relation(fields: [ownerPeerId], references: [id], onDelete: SetNull)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([fabricId, cidr])
  @@index([fabricId])
  @@index([ownerPeerId])
  @@index([status])
}

model ProjectNetworkPool {
  id             String                    @id @default(uuid())
  projectId      String
  project        Project                   @relation(fields: [projectId], references: [id])
  fabricId       String
  fabric         NetworkFabric             @relation(fields: [fabricId], references: [id])
  ipv4Cidr       String?
  ipv6Cidr       String?
  status         ProjectNetworkPoolStatus  @default(ACTIVE)
  allocationMode NetworkPoolAllocationMode @default(STATIC)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  @@unique([projectId, fabricId])
  @@index([projectId])
  @@index([fabricId])
  @@index([status])
}

model NetworkApplyOperation {
  id                String                 @id @default(uuid())
  targetType        NetworkApplyTargetType
  targetId          String
  mode              NetworkApplyMode
  status            NetworkApplyStatus     @default(PENDING)
  requestedByUserId String
  requestedByUser   User                   @relation(fields: [requestedByUserId], references: [id])
  summary           String?
  errorSummary      String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([targetType, targetId])
  @@index([requestedByUserId])
  @@index([status])
}

enum NetworkFabricStatus {
  PLANNED
  ACTIVE
  ARCHIVED
}

enum NetworkFabricMode {
  HUB_SPOKE
  MESH
}

enum WireGuardHubStatus {
  PLANNED
  ACTIVE
  ARCHIVED
}

enum NetworkPresharedKeyMode {
  DISABLED
  PAIRWISE
  FABRIC
}

enum HostNetworkPeerStatus {
  PLANNED
  ACTIVE
  ARCHIVED
}

enum HostNetworkPeerRole {
  MEMBER
  RELAY
}

enum FabricPrefixKind {
  SUBNET
  ROUTE
  RESERVED
}

enum FabricPrefixStatus {
  ACTIVE
  ARCHIVED
}

enum ProjectNetworkPoolStatus {
  ACTIVE
  ARCHIVED
}

enum NetworkPoolAllocationMode {
  STATIC
  DYNAMIC
  RESERVED
}

enum NetworkApplyTargetType {
  FABRIC
  HUB
  PEER
  PREFIX
  POOL
}

enum NetworkApplyMode {
  DRY_RUN
  APPLY
}

enum NetworkApplyStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

// M12 Phase 4: latest observed network state snapshot per endpoint, pulled
// from the trusted agent /agent/v1/network/state report. Browser-safe only;
// it never stores WireGuard private keys or preshared keys.

model NetworkStateSnapshot {
  id                    String                     @id @default(uuid())
  endpointId            String
  endpoint              AgentEndpoint              @relation(fields: [endpointId], references: [id], onDelete: Restrict)
  fabricId              String?
  fabric                NetworkFabric?             @relation(fields: [fabricId], references: [id], onDelete: SetNull)
  agentId               String
  stateSchemaVersion    Int
  observedAt            DateTime
  wireGuardAvailable    Boolean
  ipCommandAvailable    Boolean
  iptablesAvailable     Boolean
  ip6tablesAvailable    Boolean
  ipv4Forwarding        Boolean
  ipv6Forwarding        Boolean
  managedInterfaceCount Int
  status                NetworkStateSnapshotStatus @default(ONLINE)
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt

  @@unique([endpointId])
  @@index([fabricId])
}

enum NetworkStateSnapshotStatus {
  ONLINE
  OFFLINE
  ERROR
}
